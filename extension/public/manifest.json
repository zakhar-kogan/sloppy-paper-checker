{
  "manifest_version": 3,
  "name": "Sloppy Paper Checker",
  "description": "Send the current scholarly paper to Sloppy Paper Checker.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "scripting"],
  "background": {"service_worker": "assets/background.js", "type": "module"},
  "action": {"default_title": "Check this paper"},
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
  }
}
