{
  "name": "sloppy-paper-checker-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --mode pages",
    "lint": "eslint .",
    "test": "vitest run",
    "generate:types": "openapi-typescript ../openapi.json -o src/generated/api.ts"
  },
  "dependencies": {
    "pdfjs-dist": "^5.4.296",
    "preact": "^10.27.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@eslint/js": "^9.36.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "openapi-typescript": "^7.9.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
