SPC_ENV=production
SPC_API_TOKEN=replace-with-a-long-random-token
SPC_DATABASE_URL=postgresql+psycopg://paper:paper@postgres:5432/paper
SPC_DOCUMENT_STORE=filesystem
SPC_DOCUMENT_STORE_PATH=./data/documents
SPC_ANALYSIS_DISPATCHER=inline
SPC_S3_ENDPOINT_URL=
SPC_S3_REGION=eu-north1
SPC_S3_BUCKET=
SPC_S3_ACCESS_KEY_ID=
SPC_S3_SECRET_ACCESS_KEY=
SPC_NEBIUS_PROJECT_ID=
SPC_NEBIUS_JOB_IMAGE=
SPC_NEBIUS_JOB_PLATFORM=cpu-d3
SPC_NEBIUS_JOB_PRESET=4vcpu-16gb
SPC_NEBIUS_JOB_SUBNET_ID=
SPC_NEBIUS_JOB_SECRET_ID=
SPC_ALLOWED_HOSTS='["localhost","127.0.0.1","api","testserver"]'
SPC_PUBLIC_HOST=localhost

# Model inference uses an OpenAI-compatible API. Nebius Token Factory is the default.
SPC_PROVIDER_PROFILE=token_factory
SPC_PROVIDER_BASE_URL=https://api.tokenfactory.nebius.com/v1/
SPC_PROVIDER_API_KEY=
SPC_PROVIDER_API_KEY_FILE=
SPC_PROVIDER_WORKER_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
SPC_PROVIDER_REVIEWER_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507

# Backward-compatible Nebius names. These are used when the generic values above are unset.
SPC_NEBIUS_API_KEY=
SPC_NEBIUS_API_KEY_FILE=
SPC_REVIEWER_DEADLINE_SECONDS=240
SPC_TOKEN_FACTORY_WORKER_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
SPC_TOKEN_FACTORY_REVIEWER_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
SPC_UNPAYWALL_EMAIL=operator@example.org
SPC_NCBI_EMAIL=operator@example.org
SPC_REPORT_RETENTION_HOURS=24
SPC_PUBLIC_REPORT_RETENTION_DAYS=30
# Public-beta controls. Administrators authenticated with SPC_API_TOKEN bypass these limits.
SPC_LIVE_ANALYSIS_ENABLED=true
SPC_HOSTED_RUNS_PER_SESSION=10
SPC_HOSTED_RUNS_GLOBAL_24H=50
SPC_CONCURRENT_RUNS_PER_SESSION=1
SPC_PROVIDER_TIMEOUT_SECONDS=120
# Optional privacy-safe OTLP traces (compatible with Langfuse and collectors).
SPC_OBSERVABILITY_ENABLED=false
SPC_OTEL_EXPORTER_OTLP_ENDPOINT=
SPC_OTEL_EXPORTER_OTLP_HEADERS=
SPC_OTEL_SERVICE_NAME=sloppy-paper-checker
